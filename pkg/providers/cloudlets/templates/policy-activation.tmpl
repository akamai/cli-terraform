{{- /*gotype: github.com/akamai/cli-terraform/v2/pkg/providers/cloudlets.TFPolicyActivationsData*/ -}}

{{- range .Activations }}
{{ if .Commented }}/*
{{ end -}}
resource "akamai_cloudlets_policy_activation" "policy_activation_{{.Network}}" {
  policy_id             = tonumber(akamai_cloudlets_policy.policy.id)
  network               = "{{.Network}}"
  version               = akamai_cloudlets_policy.policy.version
  {{- if and (not $.IsV3) (not .Commented) .Properties }}
  associated_properties = [ {{range $i, $v := .Properties}}{{if $i}}, {{end}}"{{$v}}"{{end}} ]
  {{- else if and (not $.IsV3) .Commented }}
  associated_properties = [ "UNKNOWN_CHANGE_ME" ]
  {{- end}}
}{{- if .Commented }}*/{{ end }}
{{ end -}}